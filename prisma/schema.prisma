// This is your Prisma schema file.
// Prisma 7 — connection URL is configured in prisma.config.ts, not here.
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  engineType      = "binary"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Projects / Case Studies ─────────────────────────────────────────────────
model Project {
  id         String   @id @default(cuid())
  slug       String   @unique
  title      String
  client     String
  problem    String
  solution   String
  result     String
  tags       String
  coverImage String
  year       Int
  order      Int      @default(0)
  published  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ── Services ────────────────────────────────────────────────────────────────
model Service {
  id          String @id @default(cuid())
  title       String
  description String
  icon        String
  order       Int    @default(0)
}

// ── Testimonials ────────────────────────────────────────────────────────────
model Testimonial {
  id          String  @id @default(cuid())
  quote       String
  author      String
  role        String
  company     String
  projectSlug String?
  published   Boolean @default(true)
  order       Int     @default(0)
}

// ── Homepage Stats ──────────────────────────────────────────────────────────
model Stat {
  id    String @id @default(cuid())
  value String
  label String
  order Int    @default(0)
}

// ── Process Steps ───────────────────────────────────────────────────────────
model ProcessStep {
  id          String @id @default(cuid())
  num         String
  title       String
  description String
  order       Int    @default(0)
}

// ── Blog Posts ──────────────────────────────────────────────────────────────
model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String
  content     String
  category    String
  readTime    Int       @default(5)
  published   Boolean   @default(false)
  publishedAt DateTime?
  coverImage  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ── Contact Form Submissions ────────────────────────────────────────────────
model ContactSubmission {
  id          String   @id @default(cuid())
  name        String
  email       String
  projectType String?
  budget      String?
  message     String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// ── Admin Audit Log ─────────────────────────────────────────────────────────
// Records every admin create / update / delete action for accountability.
model AuditLog {
  id        String   @id @default(cuid())
  action    String   // "create" | "update" | "delete"
  entity    String   // model name e.g. "Project" | "Service" | "BlogPost"
  entityId  String   // record id or slug
  detail    String?  // optional human-readable summary (e.g. record title)
  createdAt DateTime @default(now())
}
